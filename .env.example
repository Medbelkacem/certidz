# ============================================================
# CertiDZ by HISN — Environment Configuration (example)
# Copy to .env and fill in real values. NEVER commit .env.
#
# The API validates these with Zod at boot (apps/api/src/config/env.ts);
# missing/invalid required values fail fast with a descriptive error.
# ============================================================

# --- Core ---
NODE_ENV=development
PORT=4000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://certidz:certidz_dev_password@localhost:5432/certidz?schema=public

# --- Redis (BullMQ queues, cache, rate limiting) ---
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# --- Auth / JWT ---
# JWT_SECRET must be at least 32 characters. Generate: openssl rand -base64 48
JWT_SECRET=dev-only-change-me-to-a-long-random-secret-of-32+chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# --- CORS (comma-separated allowlist) ---
CORS_ORIGINS=http://localhost:3000

# --- Object storage (S3-compatible — MinIO in dev) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-west-3
S3_BUCKET=certidz-dev
S3_ACCESS_KEY_ID=certidz
S3_SECRET_ACCESS_KEY=certidz_dev_secret
S3_FORCE_PATH_STYLE=true

# --- Dev CA (software PKI — replaced by HSM-backed CA in production) ---
DEV_CA_ENABLED=true

# --- WebAuthn / Passkeys ---
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=CertiDZ
WEBAUTHN_ORIGIN=http://localhost:3000

# --- Rate limiting ---
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120

# --- Observability ---
LOG_LEVEL=info

# --- External providers (optional in dev — adapters fall back to safe stubs) ---
# SMTP_URL=smtp://localhost:1025
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
IDENTITY_PROVIDER=mock
AI_PROVIDER=stub
# AI_API_KEY=

# ============================================================
# Web app (apps/web) — public runtime configuration
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
