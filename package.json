{
  "name": "certidz",
  "version": "0.1.0",
  "private": true,
  "description": "CertiDZ by HISN — The Trusted AI-Powered Digital Trust Platform for Algeria and Africa",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter @certidz/api prisma migrate dev",
    "db:generate": "pnpm --filter @certidz/api prisma generate",
    "db:seed": "pnpm --filter @certidz/api prisma db seed",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3"
  }
}
